# ============================================
# GhostVault - Frontend Environment Variables
# ============================================
# Copia este archivo como ".env" y rellena con tus valores reales

# API Configuration
# -----------------
# URL base del backend Laravel (sin slash al final)
# Ejemplo desarrollo: http://localhost:8000
# Ejemplo producción: https://api.ghostvault.com
API_DOMAIN=

# API Key para autenticación con el backend
# Obtén esta key de tu panel de administración Laravel
API_KEY=

# Application Settings (opcional)
# --------------------------------
APP_ENV=development
APP_DEBUG=true
